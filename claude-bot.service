[Unit]
Description=Claude Code Telegram Bot
After=network.target

[Service]
Type=simple
User=YOUR_SERVER_USERNAME
WorkingDirectory=/path/to/claude-telegram-dev
EnvironmentFile=/path/to/claude-telegram-dev/.env
ExecStart=/usr/bin/python3 /path/to/claude-telegram-dev/bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
